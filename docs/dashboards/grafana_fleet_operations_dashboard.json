        {
          "dataset": "telemetry",
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH mins AS (\n  SELECT\n    duty_cycle_stage,\n    COUNT(*) / 12.0 AS minutes_spent\n  FROM engine_telemetry\n  WHERE asset_id = '$asset_id'\n  GROUP BY duty_cycle_stage\n)\nSELECT\n  COALESCE(SUM(CASE WHEN duty_cycle_stage = 'LOAD'   THEN minutes_spent ELSE 0 END), 0) AS \"Load\",\n  COALESCE(SUM(CASE WHEN duty_cycle_stage = 'HAUL'   THEN minutes_spent ELSE 0 END), 0) AS \"Haul\",\n  COALESCE(SUM(CASE WHEN duty_cycle_stage = 'DUMP'   THEN minutes_spent ELSE 0 END), 0) AS \"Dump\",\n  COALESCE(SUM(CASE WHEN duty_cycle_stage = 'RETURN' THEN minutes_spent ELSE 0 END), 0) AS \"Return\",\n  COALESCE(SUM(CASE WHEN duty_cycle_stage = 'IDLE'   THEN minutes_spent ELSE 0 END), 0) AS \"Idle\"\nFROM mins;",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
          }
        }
      ],
